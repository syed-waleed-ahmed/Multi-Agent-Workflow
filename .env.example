# ---------------------------------------------------------------------------
# Campaign Forge configuration
# Copy this file to `.env` and fill in your credentials.
# All variables are optional except an API key.
# ---------------------------------------------------------------------------

# --- Authentication (one of these is required) ------------------------------
# Groq API key (default provider - free tier friendly, OpenAI-compatible).
GROQ_API_KEY=your-groq-api-key-here
# Alternatively, use an OpenAI key (also set CF_BASE_URL below to OpenAI's URL).
# OPENAI_API_KEY=your-openai-api-key-here

# --- Model / provider settings ---------------------------------------------
# OpenAI-compatible base URL. Defaults to Groq.
# CF_BASE_URL=https://api.groq.com/openai/v1
# CF_MODEL=llama-3.1-8b-instant
# CF_TEMPERATURE=0.5
# CF_MAX_TOKENS=800            # a full campaign = 4 calls; on Groq's free tier
#                              # (6000 tokens/min) use ~400 to avoid 429s

# --- Resilience -------------------------------------------------------------
# CF_REQUEST_TIMEOUT=60        # seconds per LLM request
# CF_MAX_RETRIES=4             # retries on transient API errors (honours Retry-After)

# --- Batch / scale ----------------------------------------------------------
# CF_MAX_WORKERS=4             # concurrent campaigns in batch mode

# --- Output / logging -------------------------------------------------------
# CF_OUTPUT_DIR=outputs        # where generated briefs are saved
# CF_LOG_LEVEL=INFO            # DEBUG, INFO, WARNING, ERROR
